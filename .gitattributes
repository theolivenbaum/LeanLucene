# Ensure Unix line endings for shell scripts
*.sh text eol=lf

# Benchmark data stored in Git LFS
bench/data/**/*.txt filter=lfs diff=lfs merge=lfs -text
bench/data/**/*.csv filter=lfs diff=lfs merge=lfs -text
bench/data/20newsgroups/** filter=lfs diff=lfs merge=lfs -text

# Normalise all other text files
* text=auto
